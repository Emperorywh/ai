{
  "name": "apex-coding-agent",
  "version": "1.0.0",
  "description": "基于 Claude Agent SDK 的严格线性、单并发、可恢复编码任务代理",
  "type": "module",
  "bin": {
    "apex-coding-agent": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "apex-coding-agent": "tsx src/cli/index.ts",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.10.0",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.212",
    "commander": "^15.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^26.1.1",
    "eslint": "^9.39.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
